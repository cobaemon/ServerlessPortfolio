{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B scripts/control_platform/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Loading Control Platform v2 policy"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B scripts/control_platform/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Passing Control Platform v2 contract"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B scripts/control_platform/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Classifying current-turn contract"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python -B scripts/control_platform/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Checking Control Platform v2 tool policy"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python -B scripts/control_platform/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Checking Control Platform v2 permission policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python -B scripts/control_platform/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Checking Control Platform v2 tool result policy"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B scripts/control_platform/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Checking Control Platform v2 compact preconditions"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B scripts/control_platform/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Restoring Control Platform v2 compact context"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B scripts/control_platform/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Checking Control Platform v2 subagent report"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B scripts/control_platform/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Checking Control Platform v2 final report"
          }
        ]
      }
    ]
  }
}
