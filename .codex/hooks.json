{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B .codex/hooks/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Loading comprehensive control policy"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B .codex/hooks/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Passing control contract to subagent"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B .codex/hooks/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Classifying current-turn contract"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python -B .codex/hooks/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Checking tool access"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B .codex/hooks/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Checking permission request"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python -B .codex/hooks/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Checking tool result"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B .codex/hooks/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Persisting compact control summary"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B .codex/hooks/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Restoring compact control summary"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B .codex/hooks/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Checking subagent report"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -B .codex/hooks/codex_hook_adapter.py",
            "timeout": 5,
            "statusMessage": "Checking final report"
          }
        ]
      }
    ]
  }
}
